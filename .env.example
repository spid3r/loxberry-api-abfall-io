# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and stays on your workstation.

# --- LoxBerry appliance access (only required for live deployment / tests) ---
LOXBERRY_BASE_URL=http://loxberry.local
LOXBERRY_USERNAME=your-loxberry-username
LOXBERRY_PASSWORD=your-loxberry-password
LOXBERRY_SECURE_PIN=your-loxberry-secure-pin
#LOXBERRY_AUTH_STRATEGY=basic

# Plugin folder in plugin.cfg ([PLUGIN] FOLDER=...)
# PLUGIN_FOLDER=wasteapiio

# Optional path to the plugin ZIP.
# If omitted, the latest ./dist/loxberry-plugin-wasteapiio-*.zip is used.
# PLUGIN_ZIP_PATH=

# --- Live smoke test ---
# Used by `npm run test:live:street` to drive a real lookup against api.abfall.io.
# TEST_STREET_QUERY=ExampleStreet
# TEST_STREET_NAME=
