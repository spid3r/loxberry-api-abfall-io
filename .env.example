# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and stays on your workstation.

# --- LoxBerry appliance access (only required for live deployment / tests) ---
LOXBERRY_BASE_URL=http://loxberry.local
LOXBERRY_USERNAME=your-loxberry-username
LOXBERRY_PASSWORD=your-loxberry-password
LOXBERRY_SECURE_PIN=your-loxberry-secure-pin
#LOXBERRY_AUTH_STRATEGY=basic

# Plugin folder in plugin.cfg ([PLUGIN] FOLDER=...)
# PLUGIN_FOLDER=abfallio

# Optional path to the plugin ZIP.
# If omitted, the latest ./dist/loxberry-plugin-abfallio-*.zip is used.
# PLUGIN_ZIP_PATH=

# --- Live smoke test ---
# Used by `npm run test:live:street` to drive a real lookup against api.abfall.io.
# TEST_STREET_QUERY=ExampleStreet
# TEST_STREET_NAME=

# --- E2E full lifecycle (`npm run test:e2e:full:go`) ---
# Set to 1 if your street (TEST_STREET_QUERY) is not in the region you will pick in the UI, so
# the “region autocomplete” step does not overwrite service_key.
# E2E_SKIP_SERVICE_REGION=1
# Set to 1 on hosts without HTTPS to raw.githubusercontent.com (or to skip the download).
# E2E_SKIP_SERVICE_MAP_REFRESH=1
